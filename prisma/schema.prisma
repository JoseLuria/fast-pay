generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String   @id @default(uuid()) @db.Uuid
  email    String   @unique
  name     String
  password String
  image    String?
  type     UserType @default(credentials)
}

enum UserType {
  oauth
  credentials
}
